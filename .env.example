# Template for .env.local — copy to .env.local and fill in.
# .env.local is git-ignored; .env.example is committed (no secrets).

# -----------------------------------------------------------------------------
# NBG i-Bank — credentials for scripts/sync-nbg.ts
# -----------------------------------------------------------------------------
NBG_USERNAME=
NBG_PASSWORD=

# Multi-mapping: comma-separated <label-substring>:<asset-id> pairs.
# Each substring is matched against your NBG account labels; the matched
# balance overwrites that asset's amount in portfolio.json.
NBG_MAPPINGS=3089:nbg-savings

# OTP delivery for the 2FA step.
#   manual   — stdin prompt (default; only when running with a TTY).
#   webhook  — script starts an HTTP listener on NBG_OTP_PORT and waits.
#   file     — script polls data/sync/otp-nbg.txt (used by web UI).
# When `manual` is set and you launch the sync from the dashboard, the
# script also polls the queue file as a fallback so the UI's OTP modal works.
NBG_OTP_SOURCE=manual
NBG_OTP_PORT=4848
# NBG_OTP_HOST=0.0.0.0

# Skip the auto-discovery of your investments portfolio id by hard-coding it
# here. Find it once via the URL bar at https://ebanking.nbg.gr/web/#/investments
# (it's the 6-8 digit number after /info/). Useful when NBG redesigns the page.
# NBG_PORTFOLIO_ID=

# Override these only if NBG redesigns the login page.
# NBG_USERNAME_SELECTOR=input[name="userId"]
# NBG_PASSWORD_SELECTOR=input[type="password"]
# NBG_LOGIN_BUTTON=button[type="submit"]


# -----------------------------------------------------------------------------
# Trade Republic — handled by pytr (https://github.com/marzzzello/pytr)
# -----------------------------------------------------------------------------
# International phone number (e.g. +30...) and 4-digit app PIN.
TR_PHONE_NUMBER=
TR_PIN=

# Setup once:        npm run sync:tr:setup
# Sync:              npm run sync:tr
# When session expires (every few weeks), re-run: npm run sync:tr:setup


# -----------------------------------------------------------------------------
# Notifications (email / push when sync needs human attention or fails)
# -----------------------------------------------------------------------------
# Gmail example: enable 2FA, then create an "App password" at
# https://myaccount.google.com/apppasswords and use that as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=

# Optional ntfy.sh push (free, install ntfy app on phone, pick a topic).
# NTFY_TOPIC=
# NTFY_SERVER=https://ntfy.sh


# -----------------------------------------------------------------------------
# JSON API auth (read /api/summary, trigger /api/sync)
# -----------------------------------------------------------------------------
# Long random string. Required when exposing the dashboard beyond localhost
# (e.g. behind a reverse proxy or in a Glance widget). Leave blank for fully
# open localhost-only access.
# PORTFOLIO_API_TOKEN=


# -----------------------------------------------------------------------------
# Tax estimator (page /tax)
# -----------------------------------------------------------------------------
# YYYY-MM-DD — pre-fills the birth-date field on the tax estimator so the
# under-30 benefit is applied automatically. Read server-side, not exposed
# in the client bundle. Override per-session by editing the field on the
# page (the override is saved to localStorage).
# BIRTH_DATE=1997-01-21


# -----------------------------------------------------------------------------
# AADE myDATA REST API (income / expenses for the tax estimator)
# -----------------------------------------------------------------------------
# Generate at https://www1.aade.gr/saadeapps2/bookkeeper-web →
# "Φόρμα εγγραφής στο myDATA REST API" → "Νέα εγγραφή χρήστη".
# Required by `npm run sync:mydata`. Read-only — only Request* endpoints
# are called; never anything that issues, classifies, or cancels documents.
# AADE_USER_ID=
# AADE_SUBSCRIPTION_KEY=
